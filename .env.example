# Supabase Configuration
# Get these values from: Supabase Dashboard → Settings → API → Publishable and secret API keys
# 
#  SECURITY: This file is committed to Git!
#  NEVER put real credentials here - only placeholder values!
#  Copy this file to .env and replace placeholders with your actual values

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Publishable key (sb_publishable_...) — safe for client-side use with RLS enabled
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# Legacy anon JWT still works during migration; prefer publishable key above
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key-here

# Razorpay (publishable Key ID only — never put Key Secret in the app)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Optional: where users land after tapping auth email links (must be in Supabase Redirect URLs)
EXPO_PUBLIC_AUTH_REDIRECT_URL=https://yourdomain.com/auth/confirmed

# Password reset redirect (admin forgot-password flow; add to Supabase Redirect URLs)
# Production (web): user completes reset on TankerHub in the browser, then signs in in the app
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=https://path-to-reset-password
# Local/dev (in-app deep link): uncomment and add wta://reset-password to Supabase Redirect URLs
# EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=wta://reset-password

# Server-side only (for migration scripts, not used in app)
#  NEVER commit the actual secret key to Git
#  Secret key (sb_secret_...) bypasses RLS — backend/scripts only
SUPABASE_SECRET_KEY=sb_secret_your_key_here
# Legacy service_role JWT still works during migration
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key-here
